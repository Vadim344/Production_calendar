# =============================================================================
# Schichtplaner 2.0 - Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before deploying.

# --- Database ---
# PostgreSQL connection string (use the docker service name 'postgres' as host)
DATABASE_URL="postgresql://schichtplaner:CHANGE_ME_STRONG_PASSWORD@postgres:5432/schichtplaner"

# --- Authentication ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_A_RANDOM_SECRET"
# The public URL of your app (used for OAuth callbacks, etc.)
NEXTAUTH_URL="https://schichtplaner.example.com"

# --- AI (Anthropic Claude) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Redis ---
REDIS_URL="redis://redis:6379"

# --- Object Storage (MinIO / S3) ---
S3_ENDPOINT="http://minio:9000"
S3_ACCESS_KEY="CHANGE_ME"
S3_SECRET_KEY="CHANGE_ME"
S3_BUCKET="schichtplaner"

# --- App ---
APP_URL="https://schichtplaner.example.com"

# --- Caddy (reverse proxy) ---
# Domain for automatic HTTPS via Let's Encrypt
# Use 'localhost' for local development
DOMAIN="schichtplaner.example.com"
